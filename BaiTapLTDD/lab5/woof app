class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            WoofTheme {
                Surface(modifier = Modifier.fillMaxSize()) {
                    WoofApp()
                }
            }
        }
    }
}

@Composable
fun WoofApp() {
    LazyColumn {
        items(dogs) {
            DogItem(dog = it)
        }
    }
}

/**
 * Đã gộp 2 hàm DogItem của bạn thành 1 và để padding 16dp cho to hơn
 */
@Composable
fun DogItem(
    dog: Dog,
    modifier: Modifier = Modifier
) {
    Row(
        modifier = modifier
            .fillMaxWidth()
            .padding(16.dp) // Kích thước mục to hơn ở đây
    ) {
        DogIcon(dog.imageResourceId)
        DogInformation(dog.name, dog.age)
    }
}

@Composable
fun DogIcon(
    @DrawableRes dogIcon: Int,
    modifier: Modifier = Modifier
) {
    Image(
        modifier = modifier
            .size(90.dp) // <--- CHỈNH ẢNH TO/NHỎ Ở ĐÂY
            .padding(8.dp) // <--- CHỈNH KHOẢNG CÁCH VIỀN ẢNH
            .clip(androidx.compose.foundation.shape.CircleShape), // <--- THÊM DÒNG NÀY NẾU MUỐN ẢNH TRÒN
        painter = painterResource(dogIcon),
        contentDescription = null,
        contentScale = androidx.compose.ui.layout.ContentScale.Crop // <--- GIÚP ẢNH KHÔNG BỊ MÉO
    )
}

@Composable
fun DogInformation(
    @StringRes dogName: Int,
    dogAge: Int,
    modifier: Modifier = Modifier
) {
    Column(modifier = modifier.padding(start = 12.dp)) { // Tăng khoảng cách chữ với ảnh
        Text(
            text = stringResource(dogName),
            fontSize = 22.sp, // Chữ tên to hơn
            modifier = Modifier.padding(top = 8.dp)
        )
        Text(
            text = stringResource(R.string.years_old, dogAge),
            fontSize = 18.sp // Chữ tuổi to hơn
        )
    }
}

@Preview(showBackground = true)
@Composable
fun WoofPreview() {
    WoofTheme {
        WoofApp()
    }
}
